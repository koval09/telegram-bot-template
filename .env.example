# ==============================================================================
# Stage 1 (required) — MVP core: bot + database + cache
# ==============================================================================
BOT_TOKEN=
DB_DSN=postgresql+asyncpg://bot:bot@postgres:5432/bot
REDIS_URL=redis://redis:6379/0

# Transport mode: polling (dev) | webhook (prod)
TG_MODE=polling
HTTP_HOST=0.0.0.0
HTTP_PORT=8080

# Required only when TG_MODE=webhook
WEBHOOK_PUBLIC_URL=
WEBHOOK_SECRET=

# FSM dialog inactivity timeout (minutes), default 30
FSM_TIMEOUT_MINUTES=30

# Default locale used before i18n is enabled, and as fallback when i18n is enabled
DEFAULT_LOCALE=ru

# ==============================================================================
# Stage 2 — Admin panel
# ==============================================================================
# Comma-separated list of Telegram IDs that get seeded as superadmin at startup.
# Superadmins cannot be granted via bot commands — only via this variable.
SUPERADMIN_IDS=

# ==============================================================================
# Stage 3 — TON Connect (set FEATURE_TON_CONNECTOR=true to enable)
# ==============================================================================
FEATURE_TON_CONNECTOR=false
# Public HTTPS URL to tonconnect-manifest.json (must be HTTPS, reachable from wallet apps)
TON_MANIFEST_URL=
# Values served inside tonconnect-manifest.json
# url: https URL of the app that users connect (usually the bot's landing page)
TON_APP_URL=
# Human-readable app name shown in the wallet UI (1–50 chars)
TON_APP_NAME=
# Public HTTPS URL to the app icon (PNG/ICO, 180×180 recommended)
TON_APP_ICON_URL=
# Optional extra URLs shown by some wallets
TON_APP_TERMS_URL=
TON_APP_PRIVACY_URL=

# ==============================================================================
# Stage 4 — UX and protection
# ==============================================================================
FEATURE_I18N=false
FEATURE_ANTISPAM=false
FEATURE_SUBSCRIPTIONS=false

# Comma-separated list of required channels (e.g. @my_channel,@another_channel).
# Bot must be a member/admin of each listed channel to check membership.
REQUIRED_CHANNELS=

# Comma-separated supported locales (at least DEFAULT_LOCALE must be listed)
SUPPORTED_LOCALES=ru,en

# ==============================================================================
# Stage 5 — Growth (referrals, broadcasts, stats)
# ==============================================================================
FEATURE_REFERRALS=false
FEATURE_BROADCASTS=false
FEATURE_STATS=false

# ==============================================================================
# Stage 6 — Payments (Telegram Stars and/or TON)
# ==============================================================================
FEATURE_PAYMENTS=false
# One of: stars | ton | both
PAYMENTS_PROVIDER=
# Required when PAYMENTS_PROVIDER includes TON
TON_RECEIVE_ADDRESS=
# TonCenter base URL — the client appends /api/v3/transactions internally.
# Use the root host (https://toncenter.com) or a provider-specific prefix.
TON_API_URL=https://toncenter.com
TON_API_KEY=

# ==============================================================================
# Logging
# ==============================================================================
LOG_LEVEL=INFO
